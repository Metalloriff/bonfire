theme_override_fonts/bold_font = ExtResource("2_j6fu2")
bbcode_enabled = true
text = "[color=white][b]Personal:[/b][/color] This topic will notify you for all private messages and @mentions.
[color=#9999ff]You should always be subscribed to Personal notifications in servers you care about.[/color]

[color=white][b]Announcements:[/b][/color] This topic will notify you for server announcements.
You can subscribe to this topic even if you are not a member of the server, acting as a psuedo mailing list.

[color=white][b]Public:[/b][/color] This topic will notify you for all messages sent in the server.
[color=#ff5555]Subscribing to public is only recommended for small servers.[/color]"
fit_content = true
horizontal_alignment = 1

