[node name="Label6" type="Label" parent="Modal/MarginContainer/ScrollContainer/VBoxContainer/VBoxContainer3" index="1" unique_id=466418676]
modulate = Color(1, 1, 1, 0.57254905)
custom_minimum_size = Vector2(200, 0)
layout_mode = 2
text = "Without using an open-source app like ntfy, displaying notifications while the app is minimized or closed is nearly impossible.

The only easy solution is to use Firebase FCM, ran by Google of course.
Forwarding every message through Google defeats the purpose of Bonfire.

Once you take the time to install F-Droid and ntfy, all that's needed to receive notifications for Bonfire is to press one of the three buttons above.
Pressing each button will subscribe to that topic completely automatically, as long as ntfy is installed."
horizontal_alignment = 1
autowrap_mode = 3

